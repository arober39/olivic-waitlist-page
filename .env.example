AIRTABLE_ACCESS_TOKEN=patxxxxxxxxxxxxxxxxxxxx
AIRTABLE_BASE_ID=appxxxxxxxxxxxxxx
AIRTABLE_TABLE_NAME=Waitlist
# Must include https:// — e.g. https://arober39.github.io
ALLOW_ORIGIN=https://yourusername.github.io
AIRTABLE_FIELD_NAME=name
AIRTABLE_FIELD_EMAIL=email
AIRTABLE_FIELD_GOAL=Signup Summary
AIRTABLE_FIELD_SUBMITTED_AT=submittedAt
AIRTABLE_FIELD_SOURCE=source

# If your table only has Name + Email, set these to true in Vercel:
# AIRTABLE_OMIT_SUBMITTED_AT=true
# AIRTABLE_OMIT_SOURCE=true

WAITLIST_API_URL=https://your-project.vercel.app/api/waitlist
